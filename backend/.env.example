# ============ FIREBASE CONFIGURATION ============
# CRITICAL: Required for production. Get from Firebase Console
# 1. Go to: https://console.firebase.google.com/project/aurie-5b944/settings/serviceaccounts/adminsdk
# 2. Click "Generate New Private Key"
# 3. Copy the entire JSON object and paste here as a single line
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key":"your-private-key",...}

# Firestore database URL
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com

# ============ AUTHENTICATION & SECURITY ============
# CRITICAL: Use a cryptographically random string, NOT "your-secret-key"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate-a-random-secure-string-here

# ============ TWILIO SMS CONFIGURATION (Phone Verification) ============
# CRITICAL for phone verification to work
# Get from: https://www.twilio.com/console
# Must start with "AC" and not be "demo"
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxx

# Your Twilio Auth Token
TWILIO_AUTH_TOKEN=your_auth_token

# Twilio phone number to send SMS from (E.164 format: +country_code+number)
# For India: +91xxxxxxxxxx
# For US: +1xxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ============ EMAIL CONFIGURATION (Email OTP) ============
# CRITICAL for email verification to work
# 1. Enable Less secure app access: https://myaccount.google.com/lesssecureapps
# 2. OR use App Password: https://support.google.com/accounts/answer/185833
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your_app_password_here

# Emails to receive admin notifications
ADMIN_EMAIL=admin@aurie.com

# ============ RAZORPAY PAYMENT GATEWAY ============
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY=rzp_test_xxxxxxxxxxxxx
RAZORPAY_SECRET=your_razorpay_secret

# ============ FRONTEND URLS ============
# Used in email links and CORS headers
ADMIN_DASHBOARD_URL=https://admin.aurie.com
CUSTOMER_DASHBOARD_URL=https://aurie.com
FRONTEND_URL=https://your-frontend-domain.com

# ============ SERVER CONFIGURATION ============
# Server port (use 5000 for development)
PORT=5000

# Node environment
NODE_ENV=production

# ============ IMPORTANT DEPLOYMENT NOTES ============
# 1. NEVER commit .env files to Git - use .env.example instead
# 2. By default, all logs are written to backend/logs/ with JSON format
# 3. Check logs daily for SMS/Email failures: tail -f backend/logs/sms-*.log
# 4. If phone verification fails, check TWILIO_* settings and logs
# 5. If email verification fails, check EMAIL_* settings and logs
# 6. If authentication fails, check JWT_SECRET and FIREBASE_SERVICE_ACCOUNT

